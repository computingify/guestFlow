{
  "name": "guestflow-server",
  "version": "1.0.0",
  "scripts": {
    "dev:clean": "fuser -k 4000/tcp 2>/dev/null || true",
    "dev:watch": "nodemon --watch src --ext js,json --signal SIGTERM src/index.js",
    "dev": "npm run dev:clean && npm run dev:watch",
    "start": "node src/index.js",
    "test": "node --test \"src/tests/**/*.test.js\""
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^2.1.0",
    "sharp": "^0.34.3",
    "uuid": "^9.0.0"
  }
}
